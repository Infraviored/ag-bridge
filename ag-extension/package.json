{
  "name": "ag-bridge-extension",
  "displayName": "Antigravity Bridge",
  "description": "Automates bridge injection and communication with Antigravity",
  "version": "1.0.2",
  "publisher": "infraviored",
  "repository": {
    "type": "git",
    "url": "https://github.com/Infraviored/ag-bridge"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agbridge.inject",
        "title": "AG: Inject Bridge"
      },
      {
        "command": "agbridge.showDashboard",
        "title": "AG: Show Status Dashboard"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "20.x",
    "@types/ws": "^8.5.10",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
